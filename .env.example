# ─────────────────────────────────────────────────────────────────────────────
# Apex HMS — Backend Environment Variables
# Copy to .env for local development. NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local:
DB_URL=jdbc:mysql://localhost:3306/hospital_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
# Railway (auto-filled by Railway MySQL plugin):
# DB_URL=jdbc:mysql://${MYSQLHOST}:${MYSQLPORT}/${MYSQLDATABASE}?useSSL=true&serverTimezone=UTC&allowPublicKeyRetrieval=true

DB_USERNAME=root
DB_PASSWORD=your_local_password_here

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET=Y2hhbmdlLW1lLXRvLWEtc2VjdXJlLXByb2R1Y3Rpb24ta2V5LW1pbg==
JWT_EXPIRATION=86400000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Local development (supports both Vite default ports)
FRONTEND_URL=http://localhost:5173,http://localhost:3000
# Production (set to your Vercel URL):
# FRONTEND_URL=https://your-app.vercel.app

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# ── Spring Profile ────────────────────────────────────────────────────────────
# Set to 'prod' on Railway
SPRING_PROFILES_ACTIVE=prod
